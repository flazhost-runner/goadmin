# VCS
.git
.gitignore

# Local env & secrets (never bake into the image)
.env
.env.local
*.local

# Local SQLite databases
*.db
*.sqlite
*.sqlite3

# Build artifacts / binaries
/server
/migrate
/goadmin
/goAdmin
/checkconventions
*.exe
*.test
*.out

# Coverage & profiles
coverage.txt
coverage.html
*.prof

# Runtime caches / uploads (regenerated at runtime)
web/cache/
web/uploads/
tmp/

# Editor / OS cruft
.idea/
.vscode/
*.swp
.DS_Store

# Docs not needed in the build context
docs/
