# ── GoAdmin · contoh environment ──
# Salin ke `.env` (cp .env.example .env). Hanya dibaca lewat internal/config —
# JANGAN akses env langsung di modul (di-enforce convention checker).

# Lingkungan: development | production | test
NODE_ENV=development

# Varian aplikasi dari SATU basis kode:
#   full = UI web + REST API   |   api = REST + JWT saja (stateless)
APP_MODE=full

APP_HOST=http://localhost
APP_PORT=3000
APP_NAME=GoAdmin

# ── Database (dialect-agnostic: mysql | postgres | sqlite) ──
# Dev cepat tanpa server: sqlite (file lokal). Produksi: mysql/postgres.
DB_TYPE=sqlite
DB_DATABASE=goadmin.db
# Untuk mysql/postgres, isi juga:
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_LOGGING=false
# Batas koneksi berlaku PER REPLIKA, sedangkan kuota DB terkelola dibagi ke SEMUA
# replika. Patokan: DB_CONNECTION_LIMIT ≈ kuota_tier / maks_replika (minimal 2).
# Contoh: tier 30 koneksi + auto-scale s/d 6 replika → DB_CONNECTION_LIMIT=5.
# Batas ini TIDAK membatasi jumlah request: request yang belum kebagian koneksi antre
# sesaat, bukan ditolak.
DB_CONNECTION_LIMIT=10
DB_CONNECTION_IDLE=5
DB_CONNECTION_LIFETIME_MIN=60
# Lepas koneksi nganggur setelah N menit agar kuota bisa berpindah ke replika lain.
DB_CONNECTION_IDLE_MIN=5

# ── Redis (sesi & blacklist JWT). Kosong/tak tersedia → fallback in-memory ──
REDIS_URL=redis://127.0.0.1:6379

# ── Session ──
# SESSION_DRIVER: database | redis | cookie (default: database)
#   database : sesi di tabel `sessions` DB utama (persist lintas container restart).
#   redis    : sesi di Redis server (persist lintas restart, butuh REDIS_URL).
#   cookie   : sesi di signed cookie client-side (stateless, hilang saat browser tutup).
SESSION_DRIVER=database

# ── Secret (WAJIB diisi di production — fail-fast bila kosong) ──
SESSION_SECRET=ganti-dengan-secret-acak
SESSION_TTL_HOURS=6
JWT_SECRET=ganti-dengan-secret-acak
JWT_EXPIRES_IN=1h

# ── Keamanan ──
BCRYPT_ROUNDS=10
OTP_EXPIRY_MINUTES=10
DEFAULT_PAGE_SIZE=10
# Origin CORS dipisah koma, tanpa trailing slash. Kosong = tak ada CORS.
CORS_ORIGINS=

# ── Email (reset OTP, notifikasi). MAIL_HOST kosong → mailer log saja (dev) ──
MAIL_HOST=
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_NAME=GoAdmin
MAIL_FROM_ADDRESS=no-reply@goadmin.local

# ── Frontend template switcher (landing). Remote=false → katalog kurasi (tanpa
#    jaringan, aman CI). true → fetch daftar dari TreeURL + unduh on-demand ──
FE_TEMPLATE_REMOTE=false
FE_TEMPLATE_TREE_URL=https://api.github.com/repos/lindoai/opentailwind/git/trees/master?recursive=1
FE_TEMPLATE_RAW_URL=https://raw.githubusercontent.com/lindoai/opentailwind/master/landings
FE_TEMPLATE_CACHE_DIR=web/cache/fetemplates

# ── Penyimpanan file upload (gambar: logo/avatar). local (disk) | oss | s3 ──
# Driver salah/tak lengkap membuat app MENOLAK START (dulu diam-diam jatuh ke disk
# lokal, sehingga upload seolah sukses tapi tak pernah sampai ke bucket).
STORAGE_DRIVER=local
STORAGE_DIR=web/uploads
STORAGE_URL=/uploads
# Aliyun OSS / S3 / MinIO (saat STORAGE_DRIVER=oss atau s3):
# STORAGE_ENDPOINT boleh ditulis dengan atau tanpa skema — https:// otomatis dilucuti.
#   oss → oss-ap-southeast-5.aliyuncs.com   (URL objek: https://BUCKET.ENDPOINT/key)
#   s3  → s3.amazonaws.com / play.min.io    (URL objek: https://ENDPOINT/BUCKET/key)
STORAGE_ENDPOINT=
STORAGE_REGION=
STORAGE_BUCKET=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_SSL=true
# Opsional: base URL publik (mis. CDN). Kosong = diturunkan dari driver + endpoint.
STORAGE_PUBLIC_URL=
